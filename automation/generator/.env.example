# ── Anthropic (Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gemini API ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash          # optional model override

# ── Vertex AI ──────────────────────────────────────────────────────────────
# Filename of the GCP service account JSON key — place the file in generator/
# alongside this .env. The name can be anything; set it here so teammates can
# use a different filename.
GCP_CREDENTIALS_PATH=gcp_credential_2026.json
GCP_PROJECT=my-gcp-project-id
# GCP_LOCATION=us-central1               # optional, default: us-central1
# VERTEX_MODEL=gemini-2.0-flash          # optional model override

# ── Optional path overrides ────────────────────────────────────────────────
# FRONTEND_SRC=../../frontend/src
# E2E_REFERENCE=../e2e
# OUTPUT_DIR=../e2e-generated
