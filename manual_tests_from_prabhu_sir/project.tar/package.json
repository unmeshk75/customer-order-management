{
  "name": "customer-order-management-e2e",
  "version": "1.0.0",
  "description": "Playwright E2E automation framework for Customer Order Management",
  "type": "module",
  "scripts": {
    "test":                "playwright test",
    "test:headed":         "HEADLESS=false playwright test",
    "test:ui":             "playwright test --ui",
    "test:debug":          "HEADLESS=false playwright test --debug",
    "test:customers":      "playwright test --grep TC_CUST",
    "test:products":       "playwright test --grep TC_PROD",
    "test:orders":         "playwright test --grep TC_ORD",
    "test:dashboard":      "playwright test --grep TC_DASH",
    "test:advanced":       "playwright test --grep TC_ADV",
    "test:report":         "playwright show-report",
    "install:browsers":    "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  }
}
